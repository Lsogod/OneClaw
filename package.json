{
  "name": "oneclaw",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "one": "./bin/one.mjs"
  },
  "scripts": {
    "start": "bun ./src/cli.mts",
    "ui": "bun ./src/cli.mts ui",
    "bridge": "bun ./src/bridge/server.mts",
    "install:local": "node ./scripts/install.mjs",
    "install-local": "node ./scripts/install.mjs",
    "install:smoke": "node ./scripts/install-smoke.mjs",
    "sandbox:smoke": "node ./scripts/sandbox-smoke.mjs",
    "release:check": "node ./scripts/release-check.mjs",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "test": "bun test ./tests",
    "kernel": "python3 -u -m oneclaw_kernel.server",
    "kernel:test": "node ./scripts/kernel-test.mjs",
    "ci": "bun run release:check && bun run install:smoke && bun run sandbox:smoke && bun run typecheck && bun test ./tests && node ./scripts/kernel-test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "react-devtools-core": "^6.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^6.0.2"
  }
}
