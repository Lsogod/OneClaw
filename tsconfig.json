{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.mts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "tests/**/*.mts",
    "tests/**/*.tsx"
  ]
}
